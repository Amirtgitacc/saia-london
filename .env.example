# Copy this file to .env and paste your real key. .env is gitignored.
# Get a key at https://console.anthropic.com/ (Settings → API Keys).
ANTHROPIC_API_KEY=sk-ant-replace-me

# Optional overrides:
# PORT=8787
# SAIA_MODEL=claude-haiku-4-5

# Optional: chat conversation logging (Supabase project → Settings → API).
# Without these, chat turns are printed to the server console instead.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=service-role-key
