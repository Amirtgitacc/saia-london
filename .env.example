# Copy this file to .env and paste your real key. .env is gitignored.
# Get a key at https://console.anthropic.com/ (Settings → API Keys).
ANTHROPIC_API_KEY=sk-ant-replace-me

# Optional overrides:
# PORT=8787
# SAIA_MODEL=claude-haiku-4-5

# Optional: chat conversation logging (Supabase project → Settings → API).
# Without these, chat turns are printed to the server console instead.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=service-role-key

# Optional: extra allowed browser origins for the API (comma-separated).
# The Vercel site, localhost and the standard Shopify domains are built in.
# SAIA_ALLOWED_ORIGINS=https://another-domain.com,https://foo.example

# Rate limiting. In production (Vercel) the limiter needs a shared store to
# work across stateless functions — an Upstash Redis DB (free tier) or Vercel
# KV. Set BOTH vars to that store's REST URL + token. Without them, limiting is
# per-instance best-effort only (fine for this single-process local server).
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-rest-token
# Per-IP request caps per minute (defaults shown):
# RL_CONCIERGE_PER_MIN=20
# RL_LOG_PER_MIN=60
