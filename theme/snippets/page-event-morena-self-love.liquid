  <style>
    body{ font-family:'Inter',system-ui,sans-serif; background:var(--saia-cream); color:var(--saia-ink); -webkit-font-smoothing:antialiased; text-rendering:optimizeLegibility; }
    a{ color:inherit; }
    img{ display:block; max-width:100%; }

    /* ---------- nav ---------- */
    .nav{ position:sticky; top:0; z-index:50; background:rgba(245,241,232,.92); backdrop-filter:blur(10px); border-bottom:1px solid var(--saia-line); }
    .nav-desk{ display:grid; grid-template-columns:1fr auto 1fr; align-items:center; padding:22px 48px; max-width:1480px; margin:0 auto; }
    .nav-desk nav{ display:flex; gap:30px; font-size:12px; letter-spacing:.18em; text-transform:uppercase; white-space:nowrap; }
    .nav-desk nav a{ color:var(--saia-ink); text-decoration:none; }
    .nav-desk nav a[aria-current]{ color:var(--saia-accent); }
    .brand{ text-align:center; text-decoration:none; color:var(--saia-ink); }
    .brand .mark{ font-family:'Playfair Display',serif; font-size:30px; letter-spacing:.2em; line-height:1; }
    .brand .sub{ font-size:9px; letter-spacing:.52em; text-transform:uppercase; color:var(--saia-ink-soft); margin-top:3px; }
    .nav-mob{ display:none; }
    .nav-mob-in{ display:flex; align-items:center; justify-content:space-between; padding:16px 20px; }
    .drawer{ display:none; position:fixed; inset:0; z-index:60; background:var(--saia-cream); padding:24px 28px; }
    .drawer-top{ display:flex; justify-content:space-between; align-items:center; margin-bottom:48px; }
    .drawer nav{ display:flex; flex-direction:column; gap:6px; }
    .drawer nav a{ font-family:'Playfair Display',serif; font-size:34px; color:var(--saia-ink); text-decoration:none; padding:10px 0; border-bottom:1px solid var(--saia-line); }
    .drawer nav a[aria-current]{ color:var(--saia-accent); }
    .iconbtn{ background:none; border:none; padding:6px; cursor:pointer; display:flex; }

    /* ---------- article hero ---------- */
    .back{ max-width:760px; margin:0 auto; padding:clamp(28px,4vw,40px) 6vw 0; }
    .back a{ font-size:11px; letter-spacing:.2em; text-transform:uppercase; color:var(--saia-ink-soft); text-decoration:none; display:inline-flex; align-items:center; gap:9px; }
    .back a svg{ transition:transform .25s ease; }
    .back a:hover{ color:var(--saia-accent); }
    .back a:hover svg{ transform:translateX(-4px); }

    .ahead{ max-width:760px; margin:0 auto; padding:clamp(22px,3vw,34px) 6vw clamp(28px,4vw,44px); text-align:center; }
    .eyebrow{ font-size:11px; letter-spacing:.26em; text-transform:uppercase; color:var(--saia-accent); margin-bottom:20px; }
    .ahead h1{ font-family:'Playfair Display',serif; font-weight:500; font-size:clamp(36px,5.6vw,68px); line-height:1.04; letter-spacing:-.01em; margin:0 0 24px; }
    .ahead .lede{ font-family:'Playfair Display',serif; font-style:italic; font-weight:400; font-size:clamp(19px,2.2vw,25px); line-height:1.5; color:#43403A; max-width:34ch; margin:0 auto; }

    /* ---------- cover band ---------- */
    .cover{ max-width:1080px; margin:0 auto clamp(40px,6vw,72px); padding:0 6vw; }
    .cover img{ width:100%; aspect-ratio:16/9; object-fit:cover; border-radius:5px; box-shadow:0 30px 70px -30px rgba(43,38,32,.45); }

    /* ---------- reading column ---------- */
    .read{ max-width:680px; margin:0 auto; padding:0 6vw; }
    .prose p{ font-size:clamp(16px,1.45vw,18.5px); line-height:1.85; color:#43403A; margin:0 0 26px; }
    .prose p.first::first-letter{ font-family:'Playfair Display',serif; font-size:3.4em; line-height:.82; float:left; padding:6px 12px 0 0; color:var(--saia-accent); }
    .prose a{ color:var(--saia-accent); text-decoration:none; border-bottom:1px solid rgba(184,98,74,.35); }
    .prose a:hover{ border-bottom-color:var(--saia-accent); }

    .chapter{ display:flex; align-items:baseline; gap:16px; margin:clamp(36px,5vw,60px) 0 26px; }
    .chapter .t{ font-family:'Playfair Display',serif; font-style:italic; font-size:clamp(18px,2vw,22px); color:var(--saia-ink); white-space:nowrap; }
    .chapter .rule{ flex:1; height:1px; background:var(--saia-line); }

    /* ---------- image band ---------- */
    .band{ max-width:1080px; margin:clamp(40px,6vw,76px) auto; padding:0 6vw; }
    .band figure{ margin:0; }
    .band img{ width:100%; aspect-ratio:2/1; object-fit:cover; border-radius:5px; box-shadow:0 26px 60px -30px rgba(43,38,32,.5); }
    .band figcaption{ font-size:11px; letter-spacing:.18em; text-transform:uppercase; color:var(--saia-ink-soft); margin-top:14px; padding-left:2px; }
    .band.duo figure{ display:grid; grid-template-columns:1fr 1fr; gap:clamp(14px,2vw,22px); }
    .band.duo img{ aspect-ratio:4/5; }
    .band.duo figcaption{ grid-column:1 / -1; }

    /* ---------- dark interrupt (guest / sponsor) ---------- */
    .feat{ background:var(--saia-night); color:#F5F1E8; padding:clamp(56px,8vw,104px) 6vw; margin:clamp(48px,6vw,80px) 0; }
    .feat-in{ max-width:1000px; margin:0 auto; display:grid; grid-template-columns:.9fr 1.1fr; gap:clamp(28px,4vw,56px); align-items:center; }
    .feat .eyebrow{ color:var(--saia-accent); }
    .feat img{ width:100%; aspect-ratio:4/5; object-fit:cover; border-radius:5px; box-shadow:0 30px 70px -30px rgba(0,0,0,.7); }
    .feat h2{ font-family:'Playfair Display',serif; font-weight:500; font-size:clamp(26px,3.4vw,40px); line-height:1.08; margin:14px 0 20px; }
    .feat p{ font-size:clamp(15px,1.4vw,17px); line-height:1.8; color:rgba(245,241,232,.78); margin:0 0 18px; }
    .feat p:last-child{ margin-bottom:0; }
    .feat a{ color:#F5F1E8; text-decoration:none; border-bottom:1px solid rgba(184,98,74,.6); }

    /* ---------- close ---------- */
    .close{ max-width:680px; margin:0 auto; padding:clamp(48px,7vw,88px) 6vw clamp(40px,6vw,72px); text-align:center; }
    .close p{ font-size:clamp(16px,1.5vw,18.5px); line-height:1.75; color:#43403A; margin:0 0 14px; }
    .close .toast{ font-family:'Playfair Display',serif; font-style:italic; font-size:clamp(20px,2.4vw,28px); color:var(--saia-ink); margin:0 0 36px; }
    .close .cta{ display:flex; gap:16px; justify-content:center; flex-wrap:wrap; }

    /* ---------- scroll reveal ---------- */
    .js .reveal{ opacity:0; transform:translateY(24px); transition:opacity .9s cubic-bezier(.2,.7,.2,1), transform .9s cubic-bezier(.2,.7,.2,1); }
    .js .reveal.in{ opacity:1; transform:none; }

    /* ---------- footer ---------- */
    footer{ background:var(--saia-ink); color:#F5F1E8; padding:clamp(64px,8vw,100px) 6vw 40px; }
    .foot-in{ max-width:1320px; margin:0 auto; }
    .foot-top{ display:flex; flex-wrap:wrap; gap:48px; justify-content:space-between; }
    .foot-brand{ flex:1 1 280px; max-width:360px; }
    .foot-brand .mark{ font-family:'Playfair Display',serif; font-size:34px; letter-spacing:.2em; line-height:1; }
    .foot-brand .sub{ font-size:10px; letter-spacing:.5em; text-transform:uppercase; color:rgba(245,241,232,.55); margin:6px 0 22px; }
    .foot-brand p{ font-size:14px; line-height:1.75; color:rgba(245,241,232,.65); margin:0 0 24px; max-width:300px; }
    .foot-social{ display:flex; gap:18px; margin-top:24px; }
    .foot-social a{ color:rgba(245,241,232,.7); text-decoration:none; }
    .foot-cols{ flex:0 1 auto; display:flex; flex-wrap:wrap; gap:48px; }
    .foot-col h4{ font-size:11px; letter-spacing:.22em; text-transform:uppercase; color:rgba(245,241,232,.5); margin:0 0 18px; font-weight:500; }
    .foot-col .links{ display:flex; flex-direction:column; gap:12px; font-size:14px; }
    .foot-col .links a{ color:rgba(245,241,232,.78); text-decoration:none; }
    .foot-col .links a:hover{ color:#F5F1E8; }
    .foot-bottom{ display:flex; flex-wrap:wrap; gap:14px; justify-content:space-between; align-items:center; margin-top:56px; padding-top:26px; border-top:1px solid rgba(245,241,232,.16); font-size:12px; color:rgba(245,241,232,.5); }

    /* ---------- responsive ---------- */
    @media (max-width:760px){
      .nav-desk{ display:none; }
      .nav-mob{ display:block; position:sticky; top:0; z-index:50; background:rgba(245,241,232,.94); backdrop-filter:blur(10px); border-bottom:1px solid var(--saia-line); }
      .feat-in{ grid-template-columns:1fr; }
      .band.duo figure{ grid-template-columns:1fr; }
      /* small screens: render photos at natural ratio so nothing is cropped */
      .cover img, .band img, .band.duo img, .feat img{ aspect-ratio:auto; height:auto; }
      .feat img{ max-width:420px; justify-self:center; }
    }
    @media (prefers-reduced-motion:reduce){
      .js .reveal{ opacity:1; transform:none; transition:none; }
    }
  </style>



