<main style="background:#F5F1E8; color:#2B2620; min-height:100vh; font-family:'Inter',system-ui,sans-serif; padding:48px 20px;">
  <div style="max-width:560px; margin:0 auto;">
    <a class="saia-back" href="/" style="display:inline-flex; align-items:center; gap:8px; min-height:44px; padding:8px 16px 8px 12px; margin-bottom:14px; border:1px solid #E4DDCF; border-radius:999px; background:#FBF8F1; color:#2B2620; font-size:13px; text-decoration:none;">← Back to SAÏA</a>
    <div style="font-size:11px; letter-spacing:.18em; text-transform:uppercase; color:#B8624A; margin-bottom:18px;">Your hire</div>

    {% comment %}
      Belt-and-braces: a hand-crafted /cart/<variant>:<qty> permalink can add mats without a
      plumbing line (courier two-way / one-way / NW3 pickup). Settings store variant IDs as
      text, so each is coerced to a number with `| plus: 0` before comparing against the
      integer `item.variant_id` — Liquid's `==` does not coerce string/integer types itself.
    {% endcomment %}
    {% assign saia_mat_vid = settings.variant_mat_hire | plus: 0 %}
    {% assign saia_two_way_vid = settings.variant_courier_two_way | plus: 0 %}
    {% assign saia_one_way_vid = settings.variant_courier_one_way | plus: 0 %}
    {% assign saia_pickup_vid = settings.variant_pickup | plus: 0 %}
    {% assign saia_has_mat = false %}
    {% assign saia_has_plumbing = false %}
    {% for item in cart.items %}
      {% if item.variant_id == saia_mat_vid %}
        {% assign saia_has_mat = true %}
      {% endif %}
      {% if item.variant_id == saia_two_way_vid or item.variant_id == saia_one_way_vid or item.variant_id == saia_pickup_vid %}
        {% assign saia_has_plumbing = true %}
      {% endif %}
    {% endfor %}
    {% assign saia_missing_plumbing = false %}
    {% if saia_has_mat and saia_has_plumbing == false %}
      {% assign saia_missing_plumbing = true %}
    {% endif %}

    {% if cart.item_count == 0 %}
      <p>Your cart is empty. <a href="/" style="color:#B8624A;">Plan a hire with the SAÏA assistant</a>.</p>
    {% else %}
      <form action="/cart" method="post" novalidate
            style="background:#FFFDF8; border:1px solid #E4DDCF; border-radius:8px; padding:24px;">
        {% if saia_missing_plumbing %}
          <div role="status" aria-live="polite"
               style="background:#F8E9E3; border:1px solid #B8624A; border-radius:6px; padding:14px 16px; margin-bottom:18px; font-size:13px; line-height:1.5; color:#2B2620;">
            Your delivery choice is missing from this basket — pop back through our
            <a href="/#estimate" style="color:#9E4A34; font-weight:600; text-decoration:underline;">booking flow</a>
            and we'll sort it, or delivery will be charged at checkout.
          </div>
        {% endif %}
        {% for item in cart.items %}
          <div style="display:flex; justify-content:space-between; gap:12px; padding:10px 0; border-bottom:1px solid #F0EADC;">
            <span>{{ item.product.title }}{% unless item.variant.title == 'Default Title' %} <span style="display:block; font-size:12px; color:#6B6358;">{{ item.variant.title }}</span>{% endunless %}{% if item.quantity > 1 %} <span style="color:#6B6358;">× {{ item.quantity }}</span>{% endif %}</span>
            <span>{{ item.original_line_price | money }}</span>
          </div>
        {% endfor %}
        {% for attribute in cart.attributes %}
          <div style="display:flex; justify-content:space-between; gap:12px; padding:4px 0; font-size:13px; color:#6B6358;">
            <span>{{ attribute.first }}</span><span>{{ attribute.last }}</span>
          </div>
        {% endfor %}
        <div style="display:flex; justify-content:space-between; border-top:1px solid #E4DDCF; margin-top:8px; padding-top:12px; font-family:'Playfair Display',serif; font-size:20px; color:#B8624A;">
          <span>Total today</span><span>{{ cart.total_price | money }}</span>
        </div>
        <p style="font-size:12px; color:#6B6358;">Includes the refundable deposit — returned once the mats come back. Your courier is in the total above; Cristina confirms timings with you before your event.</p>
        <button type="submit" name="checkout"
          style="width:100%; margin-top:20px; background:#2B2620; color:#F5F1E8; border:none; border-radius:4px; padding:15px; font-size:12px; letter-spacing:.18em; text-transform:uppercase; cursor:pointer;">
          Continue to payment
        </button>
      </form>
    {% endif %}
  </div>
</main>

<script>
  // backstop: clamp a hand-edited mat quantity back to 10–50 (front end already enforces this)
  (function () {
    var MIN = 10, MAX = 50, MAT_HANDLE = 'mat-hire-2-day-hire';
    var lines = [];
    {% for item in cart.items %}
      lines.push({ handle: {{ item.product.handle | json }}, line: {{ forloop.index }}, qty: {{ item.quantity }} });
    {% endfor %}
    lines.forEach(function (l) {
      if (l.handle !== MAT_HANDLE) return;
      var q = Math.min(MAX, Math.max(MIN, l.qty));
      if (q === l.qty) return;
      fetch('/cart/change.js', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ line: l.line, quantity: q })
      }).then(function (res) { if (res.ok) location.reload(); }).catch(function () { /* ignore */ });
    });
  })();
</script>
